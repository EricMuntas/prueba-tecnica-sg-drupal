{#
/**
 * @file
 * Theme override for a views mini-pager.
 *
 * Available variables:
 * - heading_id: Pagination heading ID.
 * - pagination_heading_level: The heading level to use for the pager.
 * - items: List of pager items.
 *
 * @see template_preprocess_views_mini_pager()
 */
#}
{% if items.previous or items.next %}
	<nav role="navigation" aria-labelledby="{{ heading_id }}" class="view_paginator__nav">
		<{{pagination_heading_level}} id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</{{pagination_heading_level}}>
		<ul class="js-pager__items">
			{% if items.previous %}
				<li>
					<a href="{{ items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev" {{ items.previous.attributes|without('href', 'title', 'rel') }}>
						<span class="visually-hidden">{{ 'Página anterior'|t }}</span>
						<span aria-hidden="true" class="form-submit">{{ items.previous.text|default('‹‹'|t) }}</span>
					</a>
				</li>
			{% endif %}
			{% if items.current %}
				<li>
					{% trans %}
					Página
					{{ items.current }}
					{% endtrans %}
				</li>
			{% endif %}
			{% if items.next %}
				<li>
					<a href="{{ items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next" {{ items.next.attributes|without('href', 'title', 'rel') }}>
						<span class="visually-hidden">{{ 'Siguiente página'|t }}</span>
						<span aria-hidden="true" class="form-submit">{{ items.next.text|default('››'|t) }}</span>
					</a>
				</li>
			{% endif %}
		</ul>
	</nav>
{% endif %}
